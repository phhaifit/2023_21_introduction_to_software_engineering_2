### login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### create workspace
# @name workspaceCreate
POST {{baseUrl}}/workspaces
Content-Type: application/json
Authorization: Bearer {{login.response.body.$.accessToken}}

{
  "name": "{{workspaceName}}",
  "description": "Workspace for seeding 20 demo agents",
  "templateId": "business-operations",
  "resourceProfile": "Standard",
  "region": "ap-southeast-1"
}

### set workspace running
POST {{baseUrl}}/workspaces/{{workspaceCreate.response.body.$.data.id}}/complete
Authorization: Bearer {{login.response.body.$.accessToken}}

### create agent 01
POST {{baseUrl}}/agents
Content-Type: application/json
Authorization: Bearer {{login.response.body.$.accessToken}}
X-Workspace-Id: {{workspaceCreate.response.body.$.data.id}}
X-Workspace-Role: member

{
  "name": "Support-Scout-01",
  "role": "Support Assistant",
  "model": "gpt-4o-mini",
  "instructionContent": "Answer simple support questions in short bullet points.",
  "skillFileContent": "# Skill\n\nFocus on FAQ lookup and concise responses.\n\n- Confirm issue\n- Provide next step\n",
  "status": "active"
}

