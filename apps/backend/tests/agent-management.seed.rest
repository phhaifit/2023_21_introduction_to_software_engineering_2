### login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### create workspace
# @name workspaceCreate
POST {{baseUrl}}/workspaces
Content-Type: application/json

{
  "name": "Agent Demo Workspace",
  "description": "Workspace for seeding agents",
  "templateId": "business-operations",
  "resourceProfile": "Standard",
  "region": "ap-southeast-1"
}

### set workspace running
POST {{baseUrl}}/workspaces/{{workspaceCreate.response.body.$.data.id}}/complete

### create agent 1
POST {{baseUrl}}/agents
Content-Type: application/json
Authorization: Bearer {{login.response.body.$.accessToken}}
X-Workspace-Id: {{workspaceCreate.response.body.$.data.id}}
X-Workspace-Role: member

{
  "name": "Research-Agent",
  "role": "Research Specialist",
  "model": "gpt-4.1-mini",
  "instructionContent": "Gather and summarize requirements from project docs.",
  "status": "active"
}

