{
  "name": "ai-agent-platform-for-enterprise",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace @ai-agent-platform/frontend",
    "dev:backend": "npm run dev --workspace @ai-agent-platform/backend",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "demo:reset": "npm run db:demo-reset --workspace @ai-agent-platform/backend",
    "demo:check": "npm test --workspace @ai-agent-platform/backend && npm test --workspace @ai-agent-platform/frontend && npm run typecheck && npm run build && npm run db:demo-check --workspace @ai-agent-platform/backend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
